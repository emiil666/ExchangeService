<Window x:Class="ExchangeClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" Height="620" Width="740"
        Background="#ECF0F1">
    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="5" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#566573"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="18,12">
            <StackPanel>
                <TextBlock Text="Currency Exchange Office" Foreground="White"
                           FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="Live rates from the National Bank of Poland"
                           Foreground="#AEB6BF" FontSize="11" Margin="0,1,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Converter -->
            <Border Grid.Column="0" Background="White" BorderBrush="#D5DBDB"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <StackPanel>
                    <TextBlock Text="Currency Converter" Style="{StaticResource Section}"/>
                    <TextBlock Text="Amount" Style="{StaticResource Label}"/>
                    <TextBox x:Name="AmountBox" Text="100" Style="{StaticResource Field}"/>
                    <TextBlock Text="From" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="FromBox" Height="28" Margin="0,0,0,6">
                        <ComboBoxItem Content="USD" IsSelected="True"/>
                        <ComboBoxItem Content="EUR"/>
                        <ComboBoxItem Content="GBP"/>
                        <ComboBoxItem Content="CHF"/>
                        <ComboBoxItem Content="PLN"/>
                    </ComboBox>
                    <TextBlock Text="To" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="ToBox" Height="28" Margin="0,0,0,6">
                        <ComboBoxItem Content="USD"/>
                        <ComboBoxItem Content="EUR"/>
                        <ComboBoxItem Content="GBP"/>
                        <ComboBoxItem Content="CHF"/>
                        <ComboBoxItem Content="PLN" IsSelected="True"/>
                    </ComboBox>
                    <Button x:Name="ConvertBtn" Content="Convert" Style="{StaticResource Btn}"
                            Background="#3498DB" Click="ConvertBtn_Click"/>
                    <Border Height="1" Background="#E5E8E8" Margin="0,4,0,8"/>
                    <TextBlock Text="History (days, foreign currency)" Style="{StaticResource Label}"/>
                    <TextBox x:Name="DaysBox" Text="5" Style="{StaticResource Field}"/>
                    <Button x:Name="HistoryBtn" Content="Show Historical Rates (uses From)"
                            Style="{StaticResource Btn}" Background="#5D6D7E"
                            Click="HistoryBtn_Click"/>
                </StackPanel>
            </Border>

            <!-- Account -->
            <Border Grid.Column="2" Background="White" BorderBrush="#D5DBDB"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <StackPanel>
                    <TextBlock Text="User Account" Style="{StaticResource Section}"/>
                    <TextBlock Text="Username" Style="{StaticResource Label}"/>
                    <TextBox x:Name="UsernameBox" Text="Emil" Style="{StaticResource Field}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="RegisterBtn" Content="Register"
                                Style="{StaticResource Btn}" Background="#8E44AD"
                                Click="RegisterBtn_Click"/>
                        <Button Grid.Column="2" x:Name="LoginBtn" Content="Login"
                                Style="{StaticResource Btn}" Background="#8E44AD"
                                Click="LoginBtn_Click"/>
                    </Grid>
                    <Border Background="#EAF2F8" CornerRadius="4" Padding="6" Margin="0,0,0,6">
                        <TextBlock x:Name="UserLabel" Text="No user loaded"
                                   FontWeight="Bold" FontSize="12" Foreground="#2C3E50"/>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TopUpBox" Text="5000" Style="{StaticResource Field}"/>
                        <Button Grid.Column="2" x:Name="TopUpBtn" Content="Top Up PLN"
                                Style="{StaticResource Btn}" Background="#16A085" Width="90"
                                Click="TopUpBtn_Click"/>
                    </Grid>
                    <Button x:Name="BalanceBtn" Content="Check Balance" Style="{StaticResource Btn}"
                            Background="#5D6D7E" Click="BalanceBtn_Click"/>
                    <Border Height="1" Background="#E5E8E8" Margin="0,2,0,8"/>
                    <TextBlock Text="Trade (uses Amount on the left)" Style="{StaticResource Label}"/>
                    <TextBlock Text="Currency" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="AccCurrencyBox" Height="28" Margin="0,0,0,6">
                        <ComboBoxItem Content="USD" IsSelected="True"/>
                        <ComboBoxItem Content="EUR"/>
                        <ComboBoxItem Content="GBP"/>
                        <ComboBoxItem Content="CHF"/>
                    </ComboBox>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BuyBtn" Content="Buy" Style="{StaticResource Btn}"
                                Background="#27AE60" Click="BuyBtn_Click"/>
                        <Button Grid.Column="2" x:Name="SellBtn" Content="Sell" Style="{StaticResource Btn}"
                                Background="#E67E22" Click="SellBtn_Click"/>
                    </Grid>
                    <Button x:Name="TransactionsBtn" Content="Show My Transactions"
                            Style="{StaticResource Btn}" Background="#5D6D7E"
                            Click="TransactionsBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#D5DBDB"
                BorderThickness="1" CornerRadius="8" Margin="14,0,14,14" Padding="14">
            <StackPanel>
                <TextBlock Text="RESULT" FontSize="10" FontWeight="Bold"
                           Foreground="#95A5A6" Margin="0,0,0,4"/>
                <TextBlock x:Name="ResultText" Text="Result will appear here"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="#2C3E50" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>